# AI Provider Configuration
AI_PROVIDER=claude          # Options: claude, openai
CLAUDE_API_KEY=your-claude-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devops_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Security
API_KEY=                    # Leave empty to disable API key auth (dev mode)
ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_KEY=        # Must match API_KEY above

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=60

# Debug
DEBUG=true
